# ── Example Terraform variable values ─────────────────────────────────────────
#
# Production applies don't read a `terraform.tfvars` file — values come from
# TF_VAR_* env vars in the deploy workflow, sourced from GitHub secrets and
# variables. This file documents the shape for local plan/apply experiments.
#
# To use locally:
#   cp terraform.tfvars.example terraform.tfvars
#   # edit terraform.tfvars with real values
#   terraform init -backend-config=...
#   terraform plan
#
# terraform.tfvars is gitignored — never commit one with real values.

# ── Cloudflare ──────────────────────────────────────────────────────────────
cloudflare_api_token  = "cf-api-token-redacted"
cloudflare_account_id = "0123456789abcdef0123456789abcdef"

# ── Multi-instance identity ─────────────────────────────────────────────────
# Regex: ^[a-z0-9-]+$, max length 32. Becomes the prefix for every Cloudflare
# resource name (e.g. "alghanmi" → "fluxtube-alghanmi-sync",
# "fluxtube-alghanmi-dashboard", "fluxtube-alghanmi-backups", etc.).
instance_id      = "instance-name"
dashboard_domain = "fluxtube.example.com"
history_window   = 10

# ── Sync worker (env-managed mode overlap only) ─────────────────────────────
# These are only read while the sync worker runs in env-managed mode (before
# the D1-managed cutover of Phase 9). Once admin_passkey is populated in D1,
# the sync worker ignores these entirely.
miniflux_url              = "https://reader.example.com"
category_playlist_mapping = "[{\"category\":\"YouTube — Tech\",\"playlist_id\":\"PLxxxxxxxxxxxxxxxx\"}]"
sync_log_level            = "info"
cron_schedule             = "*/30 * * * *"
cron_enabled              = true

# ── Dashboard worker ────────────────────────────────────────────────────────
dashboard_cron_schedule = "15 4 * * *"
dashboard_cron_enabled  = true
backup_retention_days   = 120

# ── Worker secrets ──────────────────────────────────────────────────────────
# Not Terraform-managed. Live in Bitwarden's `FluxTube / Worker Secrets /
# Production` item and get pushed via the deploy companion's
# scripts/sync-worker-secrets.sh (which loops over both worker names).

# ── Healthchecks.io ─────────────────────────────────────────────────────────
heartbeat_url       = "https://hc-ping.com/00000000-0000-0000-0000-000000000000"
heartbeat_url_auth  = "https://hc-ping.com/00000000-0000-0000-0000-000000000000"
heartbeat_url_quota = "https://hc-ping.com/00000000-0000-0000-0000-000000000000"

# ── Grafana Cloud (optional — empty disables) ───────────────────────────────
grafana_loki_url  = "https://logs-prod-006.grafana.net"
grafana_loki_user = "123456"
grafana_otlp_url  = "https://otlp-gateway-prod-us-east-0.grafana.net/otlp"
grafana_otlp_user = "123456"
