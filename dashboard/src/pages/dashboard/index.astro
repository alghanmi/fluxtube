---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { MappingEditor } from '../../components/MappingEditor';
---

<BaseLayout title="mappings" nav={true}>
  <h2 style="font-family: var(--font-display); font-weight: 400; margin-top: 0;">Mappings</h2>
  <p class="muted">
    Per Miniflux instance, map each category to a YouTube playlist. Save flushes changes to the
    sync worker.
  </p>

  <div style="margin-top: var(--space-6);">
    <MappingEditor client:load />
  </div>

  <script is:inline>
    // Gate the dashboard on a valid session — bounce to /login if the
    // session cookie has expired or was never set.
    (async () => {
      try {
        const r = await fetch('/api/me', { credentials: 'same-origin' });
        if (!r.ok) window.location.replace('/login');
      } catch (_e) {
        window.location.replace('/login');
      }
    })();
  </script>
</BaseLayout>
